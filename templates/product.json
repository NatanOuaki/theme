        "liquid_gUhhzm": {
          "type": "liquid",
          "settings": {
            "liquid": "{% assign current_variant = product.selected_or_first_available_variant %}\n\n<div \n  class=\"onhow-restock-notification\"\n  {% if current_variant.available %}\n    style=\"display:none;\"\n  {% endif %}\n>\n  <div class=\"onhow-restock-box\">\n    <p class=\"onhow-restock-title\">\nSoyez informé(e) dès son retour en stock\n    </p>\n\n    <p class=\"onhow-restock-subtitle\">\nLaissez votre adresse e-mail et nous vous préviendrons dès que cet article sera de nouveau disponible.\n    </p>\n\n    <form \n      method=\"post\"\n      action=\"/contact#ContactFooter\"\n      id=\"RestockForm-{{ section.id }}\"\n      accept-charset=\"UTF-8\"\n      class=\"onhow-restock-form\"\n    >\n      <input type=\"hidden\" name=\"form_type\" value=\"customer\">\n      <input type=\"hidden\" name=\"utf8\" value=\"✓\">\n\n      <input\n        type=\"hidden\"\n        name=\"contact[tags]\"\n        value=\"newsletter,restock-notification,restock-product-{{ product.handle }},restock-variant-{{ current_variant.id }}\"\n      >\n\n      <input\n        type=\"hidden\"\n        name=\"contact[body]\"\n        value=\"Demande de notification retour en stock\nProduit : {{ product.title }}\nVariante : {{ current_variant.title }}\nVariant ID : {{ current_variant.id }}\nHandle : {{ product.handle }}\"\n      >\n\n      <input\n        id=\"RestockEmail--{{ section.id }}\"\n        type=\"email\"\n        name=\"contact[email]\"\n        class=\"onhow-email-input\"\n        placeholder=\"Votre adresse email\"\n        autocomplete=\"email\"\n        required\n      >\n\n      <button\n        type=\"submit\"\n        class=\"onhow-notify-button\"\n        name=\"commit\"\n      >\nRecevoir une alerte dès le retour en stock\n      </button>\n    </form>\n\n    <p class=\"onhow-privacy-text\">\n      Aucun spam. Vos informations ne seront jamais partagées.\n    </p>\n  </div>\n</div>\n\n<style>\n.onhow-restock-notification {\n  width: 100%;\n  margin-top: 18px;\n}\n\n.onhow-restock-box {\n  border: 1px solid rgba(0,0,0,.12);\n  border-radius: 14px;\n  padding: 20px;\n  background: #fafafa;\n}\n\n.onhow-restock-title {\n  margin: 0 0 6px;\n  font-size: 18px;\n  font-weight: 600;\n  color: #111;\n  line-height: 1.3;\n}\n\n.onhow-restock-subtitle {\n  margin: 0 0 16px;\n  font-size: 14px;\n  color: rgba(0,0,0,.65);\n  line-height: 1.5;\n}\n\n.onhow-restock-form {\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n}\n\n.onhow-email-input {\n  width: 100%;\n  height: 48px;\n  padding: 0 15px;\n  border: 1px solid rgba(0,0,0,.2);\n  border-radius: 10px;\n  background: #fff;\n  color: #111;\n  font-size: 15px;\n  box-sizing: border-box;\n}\n\n.onhow-email-input:focus {\n  outline: none;\n  border-color: #111;\n  box-shadow: 0 0 0 1px #111;\n}\n\n.onhow-email-input::placeholder {\n  color: rgba(0,0,0,.45);\n}\n\n.onhow-notify-button {\n  width: 100%;\n  min-height: 50px;\n  padding: 14px 20px;\n  border: none;\n  border-radius: 10px;\n  background: #111;\n  color: #fff;\n  font-size: 15px;\n  font-weight: 600;\n  letter-spacing: .02em;\n  cursor: pointer;\n  transition: all .2s ease;\n}\n\n.onhow-notify-button:hover {\n  background: #000;\n  transform: translateY(-1px);\n}\n\n.onhow-privacy-text {\n  margin: 12px 0 0;\n  font-size: 12px;\n  color: rgba(0,0,0,.55);\n  text-align: center;\n  line-height: 1.4;\n}\n\n.onhow-toast {\n  position: fixed;\n  bottom: 24px;\n  right: 24px;\n  z-index: 999999;\n  background: #111;\n  color: #fff;\n  padding: 14px 18px;\n  border-radius: 12px;\n  font-size: 14px;\n  font-weight: 500;\n  box-shadow: 0 10px 30px rgba(0,0,0,.18);\n  opacity: 0;\n  transform: translateY(12px);\n  transition: all .3s ease;\n}\n\n.onhow-toast.show {\n  opacity: 1;\n  transform: translateY(0);\n}\n\n@media screen and (max-width: 749px) {\n  .onhow-restock-box {\n    padding: 16px;\n  }\n\n  .onhow-restock-title {\n    font-size: 16px;\n  }\n\n  .onhow-toast {\n    left: 16px;\n    right: 16px;\n    bottom: 18px;\n    text-align: center;\n  }\n}\n</style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', () => {\n  const restockWrapper = document.querySelector('.onhow-restock-notification');\n  if (!restockWrapper) return;\n\n  const productData = {{ product | json }};\n\n  function showToast(message) {\n    const toast = document.createElement('div');\n    toast.className = 'onhow-toast';\n    toast.textContent = message;\n\n    document.body.appendChild(toast);\n\n    setTimeout(() => {\n      toast.classList.add('show');\n    }, 100);\n\n    setTimeout(() => {\n      toast.classList.remove('show');\n      setTimeout(() => {\n        toast.remove();\n      }, 300);\n    }, 3500);\n  }\n\n  const urlParams = new URLSearchParams(window.location.search);\n\n  if (\n    urlParams.get('customer_posted') === 'true' ||\n    urlParams.get('contact_posted') === 'true'\n  ) {\n    showToast('Merci, vous serez notifié dès le retour en stock.');\n  }\n\n  function updateRestockVisibility() {\n    const variantIdInput =\n      document.querySelector('input[name=\"id\"]') ||\n      document.querySelector('form [name=\"id\"]');\n\n    if (!variantIdInput) return;\n\n    const currentVariantId = Number(variantIdInput.value);\n\n    const currentVariant = productData.variants.find(\n      variant => variant.id === currentVariantId\n    );\n\n    if (!currentVariant) return;\n\n    if (currentVariant.available) {\n      restockWrapper.style.display = 'none';\n    } else {\n      restockWrapper.style.display = 'block';\n\n      const bodyField = document.querySelector('input[name=\"contact[body]\"]');\n      const tagsField = document.querySelector('input[name=\"contact[tags]\"]');\n\n      if (bodyField) {\n        bodyField.value =\n          'Demande de notification retour en stock\\n' +\n          'Produit : {{ product.title }}\\n' +\n          'Variante : ' + currentVariant.title + '\\n' +\n          'Variant ID : ' + currentVariant.id + '\\n' +\n          'Handle : {{ product.handle }}';\n      }\n\n      if (tagsField) {\n        tagsField.value = [\n          'newsletter',\n          'restock-notification',\n          'restock-product-{{ product.handle }}',\n          'restock-variant-' + currentVariant.id,\n          'restock-variant-name-' + currentVariant.title.replaceAll(' ', '-').toLowerCase()\n        ].join(',');\n      }\n    }\n  }\n\n  updateRestockVisibility();\n\n  document.addEventListener('change', () => {\n    setTimeout(updateRestockVisibility, 100);\n  });\n});\n</script>"
          }
        },
