          "type": "liquid",
          "settings": {
            "liquid": "{% assign current_variant = product.selected_or_first_available_variant %}\n\n{% unless current_variant.available %}\n  <div class=\"onhow-restock-notification\">\n    <div class=\"onhow-restock-box\">\n      <p class=\"onhow-restock-title\">Prévenez-moi dès que ce produit revient</p>\n      <p class=\"onhow-restock-subtitle\">\n        Laissez votre email et nous vous informerons dès que cette variante sera de nouveau disponible.\n      </p>\n\n      <form method=\"post\" action=\"/contact#ContactFooter\" id=\"RestockForm-{{ section.id }}\" accept-charset=\"UTF-8\" class=\"onhow-restock-form\">\n        <input type=\"hidden\" name=\"form_type\" value=\"customer\">\n        <input type=\"hidden\" name=\"utf8\" value=\"✓\">\n        <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter,restock-notification\">\n        <input type=\"hidden\" name=\"contact[product]\" value=\"{{ product.title }}\">\n        <input type=\"hidden\" name=\"contact[variant]\" value=\"{{ current_variant.title }}\">\n        <input type=\"hidden\" name=\"contact[variant_id]\" value=\"{{ current_variant.id }}\">\n\n        <input \n          id=\"RestockEmail--{{ section.id }}\" \n          type=\"email\" \n          name=\"contact[email]\" \n          class=\"onhow-email-input\" \n          placeholder=\"Votre adresse email\"\n          autocomplete=\"email\"\n          required\n        >\n\n        <button type=\"submit\" class=\"onhow-notify-button\" name=\"commit\">\n          Me prévenir quand disponible\n        </button>\n      </form>\n\n      <p class=\"onhow-privacy-text\">\n        Aucun spam. Vos informations ne seront jamais partagées.\n      </p>\n    </div>\n  </div>\n\n  <style>\n    .onhow-restock-notification {\n      width: 100%;\n      margin-top: 18px;\n    }\n\n    .onhow-restock-box {\n      border: 1px solid rgba(0,0,0,.12);\n      border-radius: 14px;\n      padding: 20px;\n      background: #fafafa;\n    }\n\n    .onhow-restock-title {\n      margin: 0 0 6px;\n      font-size: 18px;\n      font-weight: 600;\n      color: #111;\n      line-height: 1.3;\n    }\n\n    .onhow-restock-subtitle {\n      margin: 0 0 16px;\n      font-size: 14px;\n      color: rgba(0,0,0,.65);\n      line-height: 1.5;\n    }\n\n    .onhow-restock-form {\n      display: flex;\n      flex-direction: column;\n      gap: 10px;\n    }\n\n    .onhow-email-input {\n      width: 100%;\n      height: 48px;\n      padding: 0 15px;\n      border: 1px solid rgba(0,0,0,.2);\n      border-radius: 10px;\n      background: #fff;\n      color: #111;\n      font-size: 15px;\n      box-sizing: border-box;\n    }\n\n    .onhow-email-input:focus {\n      outline: none;\n      border-color: #111;\n      box-shadow: 0 0 0 1px #111;\n    }\n\n    .onhow-email-input::placeholder {\n      color: rgba(0,0,0,.45);\n    }\n\n    .onhow-notify-button {\n      width: 100%;\n      min-height: 50px;\n      padding: 14px 20px;\n      border: none;\n      border-radius: 10px;\n      background: #111;\n      color: #fff;\n      font-size: 15px;\n      font-weight: 600;\n      letter-spacing: .02em;\n      cursor: pointer;\n      transition: all .2s ease;\n    }\n\n    .onhow-notify-button:hover {\n      background: #000;\n      transform: translateY(-1px);\n    }\n\n    .onhow-privacy-text {\n      margin: 12px 0 0;\n      font-size: 12px;\n      color: rgba(0,0,0,.55);\n      text-align: center;\n      line-height: 1.4;\n    }\n\n    @media screen and (max-width: 749px) {\n      .onhow-restock-box {\n        padding: 16px;\n      }\n\n      .onhow-restock-title {\n        font-size: 16px;\n      }\n    }\n  </style>\n{% endunless %}\n\n<script>\ndocument.addEventListener('DOMContentLoaded', () => {\n\n  const restockWrapper = document.querySelector('.onhow-restock-notification');\n\n  if (!restockWrapper) return;\n\n  const productData = {{ product | json }};\n\n  function updateRestockVisibility() {\n\n    const variantIdInput =\n      document.querySelector('input[name=\"id\"]') ||\n      document.querySelector('form [name=\"id\"]');\n\n    if (!variantIdInput) return;\n\n    const currentVariantId = Number(variantIdInput.value);\n\n    const currentVariant = productData.variants.find(\n      variant => variant.id === currentVariantId\n    );\n\n    if (!currentVariant) return;\n\n    if (currentVariant.available) {\n      restockWrapper.style.display = 'none';\n    } else {\n      restockWrapper.style.display = 'block';\n\n      // Update hidden fields\n      const variantField = document.querySelector(\n        'input[name=\"contact[variant]\"]'\n      );\n\n      const variantIdField = document.querySelector(\n        'input[name=\"contact[variant_id]\"]'\n      );\n\n      if (variantField) {\n        variantField.value = currentVariant.title;\n      }\n\n      if (variantIdField) {\n        variantIdField.value = currentVariant.id;\n      }\n    }\n  }\n\n  // Initial load\n  updateRestockVisibility();\n\n  // Listen for variant changes\n  document.addEventListener('change', (event) => {\n\n    if (\n      event.target.matches('input[name=\"id\"]') ||\n      event.target.closest('variant-selects') ||\n      event.target.closest('variant-radios')\n    ) {\n\n      setTimeout(() => {\n        updateRestockVisibility();\n      }, 100);\n\n    }\n\n  });\n\n});\n</script>"
