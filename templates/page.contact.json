dth=\"24\"\n  height=\"24\"\n/>\n        </a>\n\n        <a href=\"mailto:galustudio111@gmail.com\" class=\"contact-split-section__contact-item\">\n          <span class=\"contact-split-section__value\">galustudio111@gmail.com</span>\n<img \n  class=\"contact-split-section__icon-img\"\n  src=\"https://cdn.shopify.com/s/files/1/0971/5145/1440/files/material-symbols-light_mail-outline.png?v=1776325558\"\n  alt=\"Enveloppe\"\n  width=\"24\"\n  height=\"24\"\n/>\n        </a>\n\n        <a href=\"https://wa.me/972545012202\" class=\"contact-split-section__contact-item text_to_underline\" target=\"_blank\" rel=\"noopener\">\n          <span class=\"contact-split-section__value\">שירות לקוחות בוואטאפ</span>\n<img \n  class=\"contact-split-section__icon-img\"\n  src=\"https://cdn.shopify.com/s/files/1/0971/5145/1440/files/streamline-logos_whatsapp-logo.png?v=1776325559\"\n  alt=\"WhatsApp\"\n  width=\"24\"\n  height=\"24\"\n/>\n        </a>\n      </div>\n\n      <div class=\"contact-split-section__hours\">\n        <p><strong>שעות פתיחה:</strong></p>\n        <p>ימי ראשון - חמישי: 9:00-17:00</p>\n        <p>ימי שישי: 9:00-13:00</p>\n        <p>שבת: סגור</p>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<style>\n  .contact-split-section {\ndirection:ltr;\n    background: #FFFFFF;\n    padding: 0px 24px;\n  }\n\n  .contact-split-section__inner {\n    max-width: 1300px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 90px;\n    align-items: start;\n  }\n\n  .contact-split-section__form-col {\n    order: 1;\n    max-width: 500px;\n    width: 100%;\n    justify-self: start;\n    text-align: center;\n  }\n\n  .contact-split-section__info-col {\n    order: 2;\n    max-width: 600px;\n    width: 100%;\n    justify-self: end;\n    text-align: right;\n    direction: rtl;\n  }\n\n  .contact-split-section__intro {\n    font-family: 'Lora', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: 24px;\n    line-height: 1.3;\n   